# Function to find factorial using recursion
def fact(n):

    # Base condition
    if n == 1:
        return 1

    # Recursive call
    else:
        return n * fact(n - 1)

# Read input
n = int(input("Enter the number: "))

# Display result
print("Factorial of", n, "is =", fact(n))


